# Docker Compose variables.
# docker compose loads this file automatically into the container environment.

# Image version
GODUCKBOT_VERSION=latest

# Telegram bot token (from @BotFather).
# Takes precedence over telegram.token in config.yaml.
TELEGRAM_TOKEN=

# PostgreSQL password (only needed with --profile postgres)
# Overrides database.password in config.yaml
GODUCKBOT_DB_PASSWORD=
